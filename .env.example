GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile
BGE_MODEL_NAME=BAAI/bge-small-en-v1.5

# Groq free-tier limits for llama-3.3-70b-versatile (client-side guardrails)
GROQ_MAX_REQUESTS_PER_MINUTE=30
GROQ_MAX_REQUESTS_PER_DAY=1000
GROQ_MAX_TOKENS_PER_MINUTE=12000
GROQ_MAX_TOKENS_PER_DAY=100000
GROQ_MAX_OUTPUT_TOKENS=256

# API settings
CHAT_REQUESTS_PER_MINUTE=25
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:5500
DEV_MODE=false
